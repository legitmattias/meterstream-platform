# MongoDB Configuration
MONGODB_URL=mongodb://localhost:27017
DATABASE_NAME=meterstream_auth

# JWT Configuration
JWT_SECRET_KEY=your-super-secret-jwt-key-change-me
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
