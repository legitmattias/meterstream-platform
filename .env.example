# MeterStream Development Environment Configuration
# Copy this file to .env and adjust values as needed

# MongoDB
MONGODB_USERNAME=admin
MONGODB_PASSWORD=password

# JWT Secret (shared between Auth and Gateway)
JWT_SECRET=test-secret-for-local-dev

# InfluxDB
INFLUXDB_INIT_MODE=setup
INFLUXDB_INIT_USERNAME=admin
INFLUXDB_INIT_PASSWORD=password123
INFLUXDB_INIT_ORG=meterstream
INFLUXDB_INIT_BUCKET=meter_readings
INFLUXDB_ADMIN_TOKEN=my-super-secret-admin-token
